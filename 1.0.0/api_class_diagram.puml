package "reader" as reader {

+class "**final** ReaderApiProperties" as ApiProperties <<green>> {
    +{static} **final** String VERSION
}
+interface "ReaderApiFactory" as ReaderApiFactory <<blue>> {
    +CardSelectionManager createCardSelectionManager ()

    +BasicCardSelector createBasicCardSelector ()
    +IsoCardSelector createIsoCardSelector ()
}

' SERVICE
+interface CardReader {
    +String getName ()
    +boolean isContactless ()

    +boolean isCardPresent ()
}
+interface ObservableCardReader<T extends CardDetectionParameters> extends CardReader {
    +<color:red><s>void setReaderObservationExceptionHandler (CardReaderObservationExceptionHandlerSpi exceptionHandler)</s>

    +<color:red><s>void addObserver (CardReaderObserverSpi observer)</s>
    +<color:red><s>void removeObserver (CardReaderObserverSpi observer)</s>
    +<color:red><s>void clearObservers ()</s>
    +<color:red><s>int countObservers ()</s>

    +<color:red><s>void startCardDetection (DetectionMode detectionMode)</s>
    +<color:blue>void startCardDetection (T cardDetectionParameters, CardReaderEventHandler eventHandler)
    +void stopCardDetection ()

    +<color:red><s>void finalizeCardProcessing ()
    +<color:blue>void endCardProcessing ()
}
+interface "<color:red><s>ConfigurableCardReader" as ConfigurableCardReader extends CardReader {
    +<color:red><s>void activateProtocol (String physicalProtocolName, String logicalProtocolName)
    +<color:red><s>void deactivateProtocol (String physicalProtocolName)
    +<color:red><s>String getCurrentProtocol ()
}
+interface "<color:blue>ContactObservableCardReader" as ContactObservableCardReader extends ObservableCardReader {
}
+interface "<color:blue>ContactlessObservableCardReader" as ContactlessObservableCardReader extends ObservableCardReader {
    +<color:blue>RfTechnology getDetectedRfTechnology ()
    +<color:blue>CardType getDetectedCardType ()
}
+interface "<color:blue>EnhancedPollingObservableCardReader" as EnhancedPollingObservableCardReader extends ObservableCardReader {
    +<color:blue>RfTechnology getDetectedRfTechnology ()
    +<color:blue>CardType getDetectedCardType ()
}
+interface "<color:blue>CardDetectionParameters" as CardDetectionParameters {
	+<color:blue>DetectionMode getDetectionMode ()
}
+interface "<color:blue>ContactlessCardDetectionParameters" as ContactlessCardDetectionParameters extends CardDetectionParameters {
	+<color:blue>Set<RfTechnology> getRfTechnologies ()
}
+interface "<color:blue>EnhancedPollingCardDetectionParameters" as EnhancedPollingCardDetectionParameters extends ContactlessCardDetectionParameters {
	+<color:blue>byte[] getEcpFrame ()
}
+enum "<color:blue>RfTechnology" as RfTechnology <<green>> {
    <color:blue>ISO_14443_AB
    <color:blue>INNOVATRON_B_PRIME
    <color:blue>FELICA
    <color:blue>ISO_15693
}
+enum "<color:blue>CardType" as CardType <<green>> {
    <color:blue>ISO_14443_4A
    <color:blue>ISO_14443_4B
    <color:blue>ISO_14443_3A_MIFARE_CLASSIC_1K
    <color:blue>ISO_14443_3A_MIFARE_CLASSIC_4K
    <color:blue>ISO_14443_3A_MIFARE_ULTRALIGHT
    <color:blue>ISO_14443_3B_ST25_SRT512
    <color:blue>INNOVATRON_B_PRIME
    <color:blue>FELICA
    <color:blue>ISO_15693
    <color:blue>UNKNOWN
}
+enum DetectionMode <<green>> {
    REPEATING
    <color:red><s>SINGLESHOT
    <color:blue>SINGLE_SHOT
}
+enum "<color:red><s>NotificationMode" as NotificationMode <<green>> {
    <color:red><s>ALWAYS
    <color:red><s>MATCHED_ONLY
}
+enum "<color:red><s>ChannelControl" as ChannelControl <<green>> {
    <color:red><s>KEEP_OPEN
    <color:red><s>CLOSE_AFTER
}
+interface CardReaderEvent {
    +String getReaderName ()
    +Type getType ()
    +ScheduledCardSelectionsResponse getScheduledCardSelectionsResponse ()
}
+enum "Type" as CardReaderEventType <<green>> {
    CARD_INSERTED
    CARD_MATCHED
    CARD_REMOVED
    <color:red><s>UNAVAILABLE
    <color:blue>READER_UNREGISTERED
}
' SPI
package "spi" as readerSpi {
    +interface "<color:blue>CardReaderEventHandler" as CardReaderEventHandler <<red>> {
        +<color:blue>void onReaderEvent (CardReaderEvent cardReaderEvent)
        +<color:blue>void onReaderError (String context, String readerName, Throwable e)
    }
    +interface "<color:red><s>CardReaderObserverSpi</s>" as CardReaderObserverSpi <<red>> {
        +<color:red><s>void onReaderEvent (CardReaderEvent cardReaderEvent)</s>
    }
    +interface "<color:red><s>CardReaderObservationExceptionHandlerSpi</s>" as CardReaderObservationExceptionHandlerSpi <<red>> {
        +<color:red><s>void onReaderObservationError (String contextInfo, String readerName, Throwable e)</s>
    }
}

' SELECTION
package "selection" as selectionApi {
    ' Selection
    +interface CardSelectionManager <<blue>> {
        +<color:red><s>void setMultipleSelectionMode ()

        +int prepareSelection (CardSelector<?> cardSelector, CardSelectionExtension cardSelectionExtension)
        +<color:red><s>void prepareReleaseChannel ()

        +String exportCardSelectionScenario ()
        +int importCardSelectionScenario (String cardSelectionScenario)

        +<color:red><s>CardSelectionResult processCardSelectionScenario (CardReader cardReader)
        +<color:blue>CardSelectionResult processCardSelectionScenario (CardReader cardReader, SelectionExecutionPolicy selectionExecutionPolicy)

        +<color:red><s>void scheduleCardSelectionScenario (ObservableCardReader observableCardReader, NotificationMode notificationMode)
        +<color:blue>void scheduleCardSelectionScenario (ObservableCardReader observableCardReader, CardPresenceNotificationPolicy cardPresenceNotificationPolicy, SelectionExecutionPolicy selectionExecutionPolicy)
        +CardSelectionResult parseScheduledCardSelectionsResponse (ScheduledCardSelectionsResponse scheduledCardSelectionsResponse)

        +<color:blue>CardSelectionResult processMultichannelCardSelectionScenario (CardReader cardReader, ChannelSelectionPolicy channelSelectionPolicy)

        +String exportProcessedCardSelectionScenario ()
        +CardSelectionResult importProcessedCardSelectionScenario (String processedCardSelectionScenario)
    }
    +enum "<color:blue>CardPresenceNotificationPolicy" as CardPresenceNotificationPolicy <<green>> {
        <color:blue>ALWAYS
        <color:blue>MATCHED_ONLY
    }
    +enum "<color:blue>SelectionExecutionPolicy" as SelectionExecutionPolicy <<green>> {
        <color:blue>STOP_ON_FIRST_MATCH
        <color:blue>PROCESS_ALL
    }
    +enum "<color:blue>ChannelSelectionPolicy" as ChannelSelectionPolicy <<green>> {
        <color:blue>ALLOW_BASIC_CHANNEL
        <color:blue>LOGICAL_CHANNEL_ONLY
    }
    +interface "CardSelector<T extends CardSelector<T>>" as CardSelector {
        +<color:red><s>T filterByCardProtocol (String logicalProtocolName)
        +<color:blue>T filterByRfTechnology (RfTechnology rfTechnology)
        +<color:blue>T filterByCardType (CardType cardType)
        +T filterByPowerOnData (String powerOnDataRegex)
    }
    +interface "BasicCardSelector" as BasicCardSelector <<blue>> extends CardSelector {
    }
    +interface "IsoCardSelector" as IsoCardSelector <<blue>> extends CardSelector {
        +IsoCardSelector filterByDfName (byte[] aid)
        +IsoCardSelector filterByDfName (String aid)

        +IsoCardSelector setFileOccurrence (FileOccurrence fileOccurrence)
        +IsoCardSelector setFileControlInformation (FileControlInformation fileControlInformation)
    }
    +enum "FileOccurrence" as FileOccurrence <<green>> {
        FIRST
        LAST
        NEXT
        PREVIOUS
    }
    +enum "FileControlInformation" as FileControlInformation <<green>> {
        FCI
        FCP
        FMD
        NO_RESPONSE
    }

    ' Card Extension SPI
    package "spi" as selectionSpi {
        +interface "CardSelectionExtension" as CardSelectionExtension <<red>> {
        }
        +interface "SmartCard" as SmartCard <<red>> {
            +String getPowerOnData ()
            +<color:blue>boolean isActive ()
        }
        +interface "IsoSmartCard" as IsoSmartCard <<red>> extends SmartCard {
            +byte[] getSelectApplicationResponse ()
            +<color:blue>boolean isBasicChannel ()
        }
    }
    +interface CardSelectionResult {
        +Map<Integer, SmartCard> getSmartCards ()
        +SmartCard getActiveSmartCard ()
        +int getActiveSelectionIndex ()
        +<color:blue>List<Integer> getActiveSelectionIndexes ()
    }
    note bottom of CardSelectionResult
        getActiveSmartCard(): In case of multiple active smart cards,
        the active smart card on channel 0 is returned.
        Use getActiveSelectionIndexes() to get all active selection indexes.
    end note
    +interface ScheduledCardSelectionsResponse {
    }

    +class "<color:red><s><<RuntimeException>>\n<color:red><s>InvalidCardResponseException" as InvalidCardResponseExceptionOld <<green>> {
        +<color:red><s>InvalidCardResponseException (String message)
        +<color:red><s>InvalidCardResponseException (String message, Throwable cause)
    }
}

' TRANSACTION
package "transaction" as transactionApi {
    package "spi" as transactionSpi {
        +interface "CardTransactionManager" as CardTransactionManager<T extends CardTransactionManager<T>> <<red>> {
            +<color:red><s>T processCommands (ChannelControl channelControl)
            +<color:blue>T processCommands ()
        }
        +interface "<color:blue>MultichannelCardTransactionManager" as MultichannelCardTransactionManager<T extends MultichannelCardTransactionManager<T>> <<red>> extends CardTransactionManager {
            +<color:blue>T processCommandsAndCloseChannel ()
            +<color:blue>T closeChannel ()
        }
    }
}

